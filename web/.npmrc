; GitLab's npm registry requires the numeric project ID (the
; URL-encoded path form fails on the npm metadata endpoint even
; though it works for most other API calls). Project 82110648 is
; gitlab.com/dunn.dev/reference.
@dunn.dev:registry=https://gitlab.com/api/v4/projects/82110648/packages/npm/
//gitlab.com/api/v4/projects/82110648/packages/npm/:_authToken=${CI_JOB_TOKEN}
